<!doctype html>

<html>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <title>MiniWiki</title>
        <link href="/static/article.css" rel="stylesheet" />
        <link rel="icon" type="image/x-icon" href="/static/favicon.ico">
        <script src="/static/search.js" defer></script>
    </head>
    <body>
        <div class="container">
            <div class="container-header">
                <div class="header card">
                    <div class="header-navigation">
                        <a class="header-title-link" href="/">MiniWiki</a>
                        {{ if ne .Mode "home" }}
                            <span class="header-subtitle">{{ .Title }}</span>
                        {{ end }}
                    </div>
                    <div class="header-option">
                        <form class="search-form" action="/search" method="get">
                            <input
                                class="search-input"
                                type="search"
                                name="q"
                                autocomplete="off"
                                data-search-suggest="true"
                                data-search-suggest-context="content"
                                placeholder="Search pages..."
                                value="{{ .Search.Query }}"
                            />
                        </form>
                    </div>
                </div>
            </div>
            <div class="container-body">
                <div class="container-sidebar">
                    <div class="sidebar">
                        <div class="sidebar-title">Navigation</div>
                        {{ range $key, $value := .Navigation }}
                            {{ if $value }}
                                <a class="sidebar-section-link" href="{{ $key.Link }}">{{ $key.Title }}</a>
                                <ul>
                                {{ range $value }}
                                    <li><a href="{{ .Link }}">{{ .Title }}</a></li> 
                                {{ end }}
                                </ul>
                            {{ end }}
                        {{ end }}
                    </div>
                </div>
                <div class="container-content">
                    <div class="content {{ if eq .Mode "article" }}content-article{{ else }}content-ui{{ end }}">
                        {{ if eq .Mode "home" }}
                            {{ template "home" . }}
                        {{ else if eq .Mode "search" }}
                            {{ template "search" . }}
                        {{ else if .Content }}
                            {{ template "article" . }}
                        {{ else }}
                            {{ template "directory" . }}
                        {{ end }}
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>

{{ define "article" }}
    {{ .Content }}
{{ end }}

{{ define "directory" }}
    <div class="directory-overview">
        <h1>{{ .Title }}</h1>
        {{ if .Directory.Articles }}
            <section class="directory-group">
                <h2 class="directory-group-title">Articles</h2>
                <ul class="directory-group-list">
                    {{ range .Directory.Articles }}
                        <li><a class="directory-link" href="{{ .Link }}">{{ .Title }}</a></li>
                    {{ end }}
                </ul>
            </section>
        {{ end }}
        {{ if .Directory.Topics }}
            <section class="directory-group">
                <h2 class="directory-group-title">Topics</h2>
                <ul class="directory-group-list">
                    {{ range .Directory.Topics }}
                        <li><a class="directory-link" href="{{ .Link }}">{{ .Title }}</a></li>
                    {{ end }}
                </ul>
            </section>
        {{ end }}
    </div>
{{ end }}

{{ define "home" }}
    <section class="home-hero">
        <h1>Welcome to MiniWiki</h1>
        <p class="home-subtitle">Search all pages first, then explore topics in the sidebar.</p>
        <div class="home-search-wrap">
            <form class="home-search-form" action="/search" method="get">
                <input
                    class="home-search-input"
                    type="search"
                    name="q"
                    autocomplete="off"
                    autofocus
                    data-search-suggest="true"
                    data-search-autofocus="true"
                    data-search-suggest-context="landing"
                    placeholder="Search pages and article contents..."
                    aria-label="Search pages"
                />
            </form>
        </div>
    </section>
{{ end }}

